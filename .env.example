# Kalshi (required for live trading)
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./config/kalshi_private.pem

# LLM providers
GROK_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Data sources
FRED_API_KEY=
TOMORROW_API_KEY=
ODDS_API_KEY=

# Discord bot tokens (one per agent)
DONNIE_TOKEN=
WEATHER_TOKEN=
BRAD_TOKEN=
RUGRAT_TOKEN=
JORDAN_TOKEN=
MARK_HANNA_TOKEN=
CHESTER_TOKEN=
STRATTON_TOKEN=

# Dashboard API (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to 'true' to use fixture data instead of live API (for demos)
NEXT_PUBLIC_USE_FIXTURES=false
